local SUPPORTED_CLASSES = {
	Folder = true,
	Script = true,
	ModuleScript = true,
}

local function setScriptEnabled(scriptObject: Script, enabled: boolean)
	pcall(function()
		scriptObject.Enabled = enabled
	end)

	pcall(function()
		scriptObject.Disabled = not enabled
	end)
end

local function setScriptRunContext(scriptObject: Script, runContextName: string?)
	if not runContextName then
		return
	end

	local runContext = Enum.RunContext[runContextName]

	if runContext then
		pcall(function()
			scriptObject.RunContext = runContext
		end)
	end
end

local function setSource(container: LuaSourceContainer, source: string)
	local okService, ScriptEditorServiceOrError = pcall(function()
		return game:GetService("ScriptEditorService")
	end)

	if okService then
		local ScriptEditorService = ScriptEditorServiceOrError

		local okUpdate = pcall(function()
			ScriptEditorService:UpdateSourceAsync(container, function()
				return source
			end)
		end)

		if okUpdate then
			return
		end
	end

	local okDirect, directError = pcall(function()
		container.Source = source
	end)

	if not okDirect then
		error(
			("Could not write Source for %s. Run this bootstrapper in Studio/plugin/command-bar context. Error: %s")
				:format(container:GetFullName(), tostring(directError))
		)
	end
end

local function createNode(node, parent: Instance): Instance
	if not SUPPORTED_CLASSES[node.c] then
		error(("Unsupported class in bootstrapper data: %s"):format(tostring(node.c)))
	end

	local object = Instance.new(node.c)
	object.Name = node.n

	if object:IsA("Script") then
		setScriptEnabled(object, false)
		setScriptRunContext(object, node.r)
	end

	object.Parent = parent

	if object:IsA("LuaSourceContainer") then
		setSource(object, node.s or "")
	end

	for _, childNode in ipairs(node.children or {}) do
		createNode(childNode, object)
	end

	if object:IsA("Script") then
		setScriptEnabled(object, node.e ~= false)
	end

	return object
end

local existing = ServerStorage:FindFirstChild(DATA.n)

if existing then
	existing:Destroy()
end

local rebuilt = createNode(DATA, ServerStorage)

print(("Unpacked %s into %s"):format(rebuilt.Name, rebuilt:GetFullName()))
